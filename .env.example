# KATHA · Supabase configuration
#
# Copy to .env.local and fill in from your Supabase project's dashboard
# (Project Settings → API). Until these are set, the app runs entirely on
# the local (localStorage) repository implementations — Supabase is optional
# infrastructure, never a requirement for local development.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Which membership system is active — an EXPLICIT choice, never inferred from
# credential presence. 'local' (the default) keeps the on-device membership
# even when the Supabase values above are filled in; set 'supabase' to use
# real authentication.
NEXT_PUBLIC_AUTH_PROVIDER=local
