# KATHA · Supabase configuration
#
# Copy to .env.local and fill in from your Supabase project's dashboard
# (Project Settings → API). Until these are set, the app runs entirely on
# the local (localStorage) repository implementations — Supabase is optional
# infrastructure, never a requirement for local development.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
