# KATHA · Supabase configuration
#
# Copy to .env.local and fill in from your Supabase project's dashboard
# (Project Settings → API). Until these are set, the app runs entirely on
# the local (localStorage) repository implementations — Supabase is optional
# infrastructure, never a requirement for local development.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Which membership system is active — an EXPLICIT choice, never inferred from
# credential presence. 'local' (the default) keeps the on-device membership
# even when the Supabase values above are filled in; set 'supabase' to use
# real authentication.
NEXT_PUBLIC_AUTH_PROVIDER=local

# Which catalogue is active — independent of AUTH_PROVIDER, so the data
# domains stay independently swappable. 'local' (the default) serves the
# compiled demo library; 'supabase' serves published works from the database
# (seeded via supabase/seed.sql).
NEXT_PUBLIC_CATALOGUE_PROVIDER=local

# Which work repository (the Studio's drafts + publishing) is active.
# 'supabase' requires AUTH_PROVIDER=supabase — publishing writes are
# authenticated acts under RLS; without a session this falls back to local.
NEXT_PUBLIC_WORKS_PROVIDER=local
